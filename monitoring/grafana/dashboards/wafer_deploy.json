  {
   "id": 1,
   "type": "stat",
   "title": "Service up",
   "gridPos": {
    "h": 4,
    "w": 4,
    "x": 0,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "wafer-prometheus"
   },
   "fieldConfig": {
    "defaults": {
     "mappings": [
      {
       "type": "value",
       "options": {
        "0": {
         "text": "DOWN",
         "color": "red"
        }
       }
      },
      {
       "type": "value",
       "options": {
        "1": {
         "text": "UP",
         "color": "green"
        }
       }
      }
     ],
     "color": {
      "mode": "thresholds"
     },
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    }
   },
   "targets": [
    {
     "refId": "A",
     "expr": "wafer_deploy_up",
     "datasource": {
      "type": "prometheus",
      "uid": "wafer-prometheus"
     }
    }
   ]
  },
